{
  "name": "akoflow-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "build:renderer": "node scripts/build-renderer.mjs",
    "start": "npm run build:renderer && electron .",
    "dist": "npm run build:renderer && electron-builder",
    "dist:mac": "npm run build:renderer && electron-builder --mac",
    "dist:win": "npm run build:renderer && electron-builder --win",
    "dist:linux": "npm run build:renderer && electron-builder --linux"
  },
  "build": {
    "appId": "io.akoflow.desktop",
    "productName": "AkôFlow Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "category": "Development",
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "electron": "^34.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "electron-builder": "^25.0.0"
  }
}
